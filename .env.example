# ── Application ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── MongoDB (required) ─────────────────────────────────────────────────────
# Use MONGODB_URI in Railway environment variables
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/train_management

# ── Kafka (required for domain-event publishing) ───────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_ENABLED=true
KAFKA_CLIENT_ID=train-management-service

# ── Redis (optional — schedule-search cache) ───────────────────────────────
# Railway provides REDIS_URL automatically if you add a Redis service
REDIS_URL=redis://localhost:6379

# ── Security ───────────────────────────────────────────────────────────────
# Leave blank in dev; set SERVICE_API_KEY in Railway Dashboard for production
SERVICE_API_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=*
