# ── Application ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── MongoDB (required) ─────────────────────────────────────────────────────
# Option A: Full URI (takes priority over individual host/port/db vars)
MONGO_URI=mongodb://localhost:27017/train_management

# Option B: individual components (used when MONGO_URI is not set)
# MONGO_HOST=localhost
# MONGO_PORT=27017
# MONGO_DB_NAME=train_management
# MONGO_MAX_POOL_SIZE=20
# MONGO_MIN_POOL_SIZE=0
# MONGO_SERVER_SELECTION_TIMEOUT_MS=30000

# ── Kafka (required for domain-event publishing) ───────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_ENABLED=true
KAFKA_CLIENT_ID=train-management-service

# SASL/SSL — only needed when connecting to a managed/secured Kafka cluster
# KAFKA_SSL=false
# KAFKA_SASL_MECHANISM=plain
# KAFKA_USERNAME=
# KAFKA_PASSWORD=

# Topic names (defaults shown — only override if you need custom topics)
# KAFKA_TRAIN_TOPIC=train.events
# KAFKA_STATION_TOPIC=station.events
# KAFKA_ROUTE_TOPIC=route.events
# KAFKA_SCHEDULE_TOPIC=schedule.events

# ── Redis (optional — schedule-search cache) ───────────────────────────────
# Option A: Full URL (e.g. from Upstash)
# REDIS_URL=redis://localhost:6379

# Option B: individual components
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Security ───────────────────────────────────────────────────────────────
# API key required on all /api/* routes.
# Leave blank in development to bypass authentication automatically.
SERVICE_API_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all.
ALLOWED_ORIGINS=*
